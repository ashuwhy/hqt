    {
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 20 },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
