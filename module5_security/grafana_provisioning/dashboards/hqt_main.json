          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "refId": "A",
          "rawSql": "SELECT\n  bucket AS \"time\",\n  open,\n  high,\n  low,\n  close,\n  volume,\n  AVG(close) OVER(ORDER BY bucket ROWS BETWEEN 19 PRECEDING AND CURRENT ROW) as sma20,\n  AVG(close) OVER(ORDER BY bucket ROWS BETWEEN 49 PRECEDING AND CURRENT ROW) as sma50\nFROM ${interval:raw}\nWHERE\n  $__timeFilter(bucket)\n  AND symbol = '${symbol}'\nORDER BY 1"
        }
      ],
      "title": "Price OHLCV + SMA — ${symbol}  [${interval}]",
      "type": "candlestick"
