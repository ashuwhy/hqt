    },
    {
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 20 },
      "id": 7,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "TimescaleDB" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "refId": "A",
          "rawSql": "SELECT EXTRACT(EPOCH FROM (now() - max(ts)))::int AS \"lag_seconds\" FROM raw_ticks"
        }
      ],
      "title": "Data Lag (seconds)",
      "type": "stat"
    }
  ],
